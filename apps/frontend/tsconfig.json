{
  "extends": "../../packages/typescript-config/react.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": "./src",
    "types": ["vite/client", "vite-plugin-pwa/client"],
    "paths": {
      "@/*": ["./*"],
      "@components/*": ["components/*"],
      "@pages/*": ["pages/*"],
      "@hooks/*": ["hooks/*"],
      "@contexts/*": ["contexts/*"],
      "@services/*": ["services/*"],
      "@utils/*": ["utils/*"],
      "@app-types/*": ["types/*"],
      "@assets/*": ["assets/*"],
      "@styles/*": ["styles/*"],
      "@data/*": ["data/*"]
    }
  },
  "include": ["src/**/*", "vite.config.ts", "tailwind.config.ts"],
  "exclude": ["node_modules", "dist"]
}
