generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  passwordHash       String
  name               String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  alerts             Alert[]
  pushSubscriptions  PushSubscription[]

  @@map("users")
}

enum AlertChannel {
  EMAIL
  PUSH
}

model Alert {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  cityId       String
  city         City           @relation(fields: [cityId], references: [id], onDelete: Cascade)
  thresholdAqi Int
  channels     AlertChannel[]
  active       Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  dispatches   AlertDispatch[]

  @@index([userId])
  @@index([cityId, active])
  @@map("alerts")
}

model AlertDispatch {
  id        String        @id @default(cuid())
  alertId   String
  alert     Alert         @relation(fields: [alertId], references: [id], onDelete: Cascade)
  channel   AlertChannel
  aqiValue  Int
  sentAt    DateTime      @default(now())

  @@index([alertId, sentAt(sort: Desc)])
  @@map("alert_dispatches")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

model City {
  id              String       @id @default(cuid())
  name            String
  state           String
  region          String
  lat             Float
  lng             Float
  source          String       @default("seed")
  populationTotal Int?
  elderlyPct      Float?
  childrenPct     Float?
  createdAt       DateTime     @default(now())
  aqiReadings     AqiReading[]
  healthData      HealthData[]
  alerts          Alert[]

  @@unique([name, state])
  @@map("cities")
}

model AqiReading {
  id             String   @id @default(cuid())
  cityId         String
  city           City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  aqi            Int
  pm25           Float?
  pm10           Float?
  o3             Float?
  no2            Float?
  co             Float?
  uv             Float?
  pollen         Float?
  windDirection  Float?
  windSpeed      Float?
  temperature    Float?
  timestamp      DateTime @default(now())
  source         String

  @@index([cityId, timestamp(sort: Desc)])
  @@map("aqi_readings")
}

/// IBGE municipal seats (sedes) for geospatial "nearest municipality" lookups — not tied to AQI stations.
model Municipality {
  id       String @id @default(cuid())
  ibgeCode Int    @unique
  name     String
  state    String
  region   String
  lat      Float
  lng      Float

  @@map("municipalities")
}

model FireFocus {
  id         String   @id @default(cuid())
  lat        Float
  lng        Float
  intensity  Float?
  satellite  String?
  biome      String?
  state      String?
  detectedAt DateTime @default(now())

  @@unique([lat, lng, detectedAt])
  @@index([detectedAt])
  @@map("fire_focuses")
}

model DeforestationAlert {
  id         String   @id @default(cuid())
  state      String
  lat        Float?
  lng        Float?
  areaHa     Float
  biome      String?
  detectedAt DateTime
  source     String   @default("prodes")
  createdAt  DateTime @default(now())

  @@index([detectedAt])
  @@map("deforestation_alerts")
}

model HealthData {
  id                          String   @id @default(cuid())
  cityId                      String
  city                        City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  year                        Int
  month                       Int
  respiratoryHospitalizations Int
  source                      String   @default("datasus")
  createdAt                   DateTime @default(now())

  @@unique([cityId, year, month])
  @@index([cityId, year, month])
  @@map("health_data")
}

model JobLog {
  id              String   @id @default(cuid())
  collectorName   String
  status          JobStatus
  recordsInserted Int?
  errorMessage    String?
  durationMs      Int?
  startedAt       DateTime @default(now())

  @@map("job_logs")
}

enum JobStatus {
  RUNNING
  SUCCESS
  ERROR
}
