generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model City {
  id              String       @id @default(cuid())
  name            String
  state           String
  region          String
  lat             Float
  lng             Float
  source          String       @default("seed")
  populationTotal Int?
  elderlyPct      Float?
  childrenPct     Float?
  createdAt       DateTime     @default(now())
  aqiReadings     AqiReading[]
  healthData      HealthData[]

  @@unique([name, state])
  @@map("cities")
}

model AqiReading {
  id             String   @id @default(cuid())
  cityId         String
  city           City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  aqi            Int
  pm25           Float?
  pm10           Float?
  o3             Float?
  no2            Float?
  co             Float?
  uv             Float?
  pollen         Float?
  windDirection  Float?
  windSpeed      Float?
  temperature    Float?
  timestamp      DateTime @default(now())
  source         String

  @@index([cityId, timestamp(sort: Desc)])
  @@map("aqi_readings")
}

model FireFocus {
  id         String   @id @default(cuid())
  lat        Float
  lng        Float
  intensity  Float?
  satellite  String?
  biome      String?
  state      String?
  detectedAt DateTime @default(now())

  @@unique([lat, lng, detectedAt])
  @@index([detectedAt])
  @@map("fire_focuses")
}

model DeforestationAlert {
  id         String   @id @default(cuid())
  state      String
  lat        Float?
  lng        Float?
  areaHa     Float
  biome      String?
  detectedAt DateTime
  source     String   @default("prodes")
  createdAt  DateTime @default(now())

  @@index([detectedAt])
  @@map("deforestation_alerts")
}

model HealthData {
  id                          String   @id @default(cuid())
  cityId                      String
  city                        City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  year                        Int
  month                       Int
  respiratoryHospitalizations Int
  source                      String   @default("datasus")
  createdAt                   DateTime @default(now())

  @@unique([cityId, year, month])
  @@index([cityId, year, month])
  @@map("health_data")
}

model JobLog {
  id              String   @id @default(cuid())
  collectorName   String
  status          JobStatus
  recordsInserted Int?
  errorMessage    String?
  durationMs      Int?
  startedAt       DateTime @default(now())

  @@map("job_logs")
}

enum JobStatus {
  RUNNING
  SUCCESS
  ERROR
}
