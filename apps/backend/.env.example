# Ambiente de execução: development | production | test
NODE_ENV=development

# Chave para rotas /api/v1/admin (jobs). Obrigatória em produção.
# Envie: Authorization: Bearer <valor> ou header X-Admin-Key: <valor>
# Em desenvolvimento, se vazia, as rotas admin ficam abertas (apenas local).
ADMIN_API_KEY=

# Porta HTTP do servidor Express
PORT=3333

# Origens permitidas pelo CORS (separadas por vírgula)
# Produção: https://airbr-frontend.vercel.app
# Desenvolvimento: http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# URL de conexão com o banco de dados PostgreSQL
# Neon (pooler, para queries da app): postgresql://user:pass@ep-xxx-pooler.region.neon.tech/neondb?sslmode=require&channel_binding=require
# Local (Docker Compose): postgresql://postgres:postgres@localhost:5432/airbr
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/airbr

# URL direta sem pooler — usada pelo Prisma para migrações (Neon ou local)
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/airbr

# Chave da API OpenWeatherMap (gratuita, 1.000 req/dia)
# Obtenha em: https://openweathermap.org/api
OWM_API_KEY=

# Token da API AQICN (gratuito, +500 estações no Brasil)
# Obtenha em: https://aqicn.org/data-platform/token/
AQICN_TOKEN=

# Credenciais CETESB QUALAR (opcional — SP apenas)
# Cadastro em: https://qualar.cetesb.sp.gov.br/qualar/
CETESB_USERNAME=
CETESB_PASSWORD=

# Chave IEMA MONITORAR (opcional — 11 estados, 82 localidades)
# Cadastro em: https://monitorar.iema.es.gov.br/
IEMA_API_KEY=

# Chave IAT/Paraná RMAQA (opcional — Região Metropolitana de Curitiba)
# Portal: https://www.iat.pr.gov.br/Pagina/Qualidade-do-ar-RMAQA
IAT_API_KEY=

# --- Autenticação (JWT para usuários) ---
# Obrigatório em produção. Mínimo 32 caracteres.
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- E-mail transacional (alertas) ---
# Resend (recomendado): https://resend.com — ou SMTP abaixo como fallback
RESEND_API_KEY=
EMAIL_FROM=noreply@seudominio.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Web Push (VAPID) — gere com: npx web-push generate-vapid-keys ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:alerts@seudominio.com

# Horas entre notificações repetidas para o mesmo alerta (cooldown)
ALERT_COOLDOWN_HOURS=6
