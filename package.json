{
  "name": "airbr",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@types/node-cache": "^4.1.3",
    "cors": "^2.8.6",
    "fast-xml-parser": "^5.5.9",
    "node-cache": "^5.1.2",
    "tsc-alias": "^1.8.16"
  }
}
